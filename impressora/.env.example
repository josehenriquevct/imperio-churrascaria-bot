# URL do Firebase Realtime Database
FIREBASE_DB_URL=https://esquina-burger-default-rtdb.firebaseio.com

# Prefixo dos dados no Firebase
FIREBASE_PREFIX=imperio

# Intervalo de checagem em segundos (padrao: 5)
INTERVALO_CHECAGEM=5

# Nome do restaurante (aparece no cupom)
RESTAURANTE_NOME=Império Churrascaria

# Telefone do restaurante (aparece no cupom)
RESTAURANTE_TELEFONE=(64) 99959-6448
